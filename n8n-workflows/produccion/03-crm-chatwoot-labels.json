    {
      "parameters": {
        "jsCode": "function firstJson(name) {\n  try { return $(name).first()?.json ?? null; } catch { return null; }\n}\n\nconst mapped = firstJson('Mapear estado -> etiqueta') ?? {};\nconst resolved = firstJson('Resolver convId') ?? {};\nconst conversation = firstJson('Chatwoot: Obtener etiquetas actuales') ?? $input.first().json ?? {};\n\nconst MANAGED_LABELS = [\n  'temp_frio','temp_tibio','temp_caliente',\n  'pipe_enviado','pipe_contactado','pipe_respondio','pipe_agendado','pipe_seguimiento','pipe_ganado','pipe_perdido',\n  'pipe_nuevo','prospecto-nuevo','contactado','respondio','llamada-agendada','en-seguimiento','cliente','descartado',\n  'int_interes','int_precio','int_demo','int_objecion','int_presupuesto','int_seguimiento','int_no_interes',\n  'requiere_humano','destacado'\n];\n\nconst currentLabels = Array.isArray(conversation.labels)\n  ? conversation.labels\n  : Array.isArray(conversation.payload)\n    ? conversation.payload\n    : [];\nconst requestedLabels = Array.isArray(mapped.labels) ? mapped.labels : [];\nconst manualLabels = currentLabels.filter((label) => !MANAGED_LABELS.includes(label));\nconst nuevasEtiquetas = [...new Set([...manualLabels, ...requestedLabels])];\nconst chatwootConversationId = mapped.chatwootConversationId ?? resolved.chatwootConversationId ?? conversation.id ?? null;\n\nreturn [{\n  json: {\n    ...mapped,\n    chatwootConversationId,\n    nuevasEtiquetas,\n  }\n}];"
      },
