          "jsCode": "const ESTADO_LABEL = {\n  enviado: 'pipe_enviado',\n  contactado: 'pipe_contactado',\n  respondio: 'pipe_respondio',\n  agendado: 'pipe_agendado',\n  seguimiento: 'pipe_seguimiento',\n  cerrado_positivo: 'pipe_ganado',\n  cerrado_negativo: 'pipe_perdido'\n};\n\nconst body = $input.first().json.body ?? $input.first().json;\nconst { prospectId, phone, nuevoEstado, chatwootConversationId } = body;\nif (!nuevoEstado && !Array.isArray(body.labels)) return [{ json: { skip: true } }];\nconst fallbackLabel = ESTADO_LABEL[nuevoEstado] ?? 'pipe_enviado';\nconst labels = Array.isArray(body.labels) && body.labels.length ? body.labels : [fallbackLabel];\nreturn [{ json: { prospectId, phone, nuevoEstado, labels, chatwootConversationId: chatwootConversationId ?? null } }];"
        },
