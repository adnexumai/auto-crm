      "position": [
        460,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "// Filtrar solo mensajes humanos salientes del inbox de WhatsApp\nconst body = $input.first().json.body ?? $input.first().json;\nconst event = body.event ?? '';\nconst messageType = body.message_type ?? '';\nconst senderType = body.sender?.type ?? '';\nconst isPrivate = body.private === true;\nconst preferredInboxId = 2;\nconst inboxId = Number(body.inbox?.id ?? body.conversation?.inbox_id ?? 0);\nconst phone = body.contact?.phone_number ?? body.contact?.phone ?? body.conversation?.meta?.sender?.phone_number ?? body.meta?.sender?.phone_number ?? '';\nconst content = (body.content ?? '').trim();\n\nif (event !== 'message_created') {\n  return [{ json: { skip: true, reason: `evento no soportado: ${event}` } }];\n}\n\nif (messageType !== 'outgoing') {\n  return [{ json: { skip: true, reason: `message_type ignorado: ${messageType}` } }];\n}\n\nif (senderType !== 'user') {\n  return [{ json: { skip: true, reason: `sender_type ignorado: ${senderType}` } }];\n}\n\nif (isPrivate) {\n  return [{ json: { skip: true, reason: 'nota privada' } }];\n}\n\nif (preferredInboxId && inboxId && preferredInboxId !== inboxId) {\n  return [{ json: { skip: true, reason: `inbox no coincide: ${inboxId}` } }];\n}\n\nif (!phone || !content) {\n  return [{ json: { skip: true, reason: 'sin phone o content' } }];\n}\n\nconst dedupeKey = body.id\n  ? `chatwoot-msg:${body.id}`\n  : `chatwoot-msg:${body.conversation?.id ?? 'sin-conv'}:${content}`;\n\nreturn [{\n  json: {\n    phone,\n    content,\n    dedupeKey,\n    messageId: body.id ?? null,\n    conversationId: body.conversation?.id ?? null,\n    inboxId: inboxId || null\n  }\n}];"
      },
