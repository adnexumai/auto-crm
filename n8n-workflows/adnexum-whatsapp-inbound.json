    {
      "parameters": {
        "jsCode": "const search = $input.first().json;\nconst contacts = search.payload ?? [];\nconst prospect = $('Extraer prospecto').first().json.prospect;\nconst phone = $('Extraer campos').first().json.phone;\nconst name = $('Extraer campos').first().json.name;\nconst content = $('Extraer campos').first().json.content;\nconst msgType = $('Extraer campos').first().json.msgType;\n\nlet existingContactId = null;\nlet existingConvId = prospect?.chatwootConversationId ?? null;\n\nif (contacts.length > 0) {\n  existingContactId = contacts[0].id;\n}\n\nreturn [{\n  json: {\n    phone,\n    name,\n    content,\n    msgType,\n    prospect,\n    existingContactId,\n    existingConvId: existingConvId || null,\n    contactId: existingContactId,\n    convId: existingConvId || null,\n    needCreateContact: !existingContactId && !existingConvId,\n    needLookupConversation: !!existingContactId && !existingConvId\n  }\n}];"
      },
