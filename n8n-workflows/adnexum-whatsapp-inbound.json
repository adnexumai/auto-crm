    {
      "parameters": {
        "jsCode": "const source = $input.first().json;\nconst createdConversation = $('Chatwoot: Crear conversación').all();\nconst convId = createdConversation.length > 0\n  ? createdConversation[0].json.id\n  : (source.convId ?? source.existingConvId ?? null);\n\nif (!convId) {\n  return [];\n}\n\nconst prospect = source.prospect ?? {};\nconst phone = source.phone ?? $('Extraer campos').first().json.phone;\nconst name = source.name ?? $('Extraer campos').first().json.name;\nconst content = source.content ?? $('Extraer campos').first().json.content;\n\nreturn [{\n  json: {\n    convId,\n    contactId: source.contactId ?? source.existingContactId ?? null,\n    prospectId: prospect.id ?? null,\n    prospectPhone: phone,\n    phone,\n    name,\n    content,\n    estado: prospect.estado ?? 'enviado',\n    score: prospect.oportunidadScore ?? 0,\n    resumenIa: prospect.resumenIa ?? ''\n  }\n}];"
      },
