        540
      ]
    },
    {
      "parameters": {
        "jsCode": "const source = $('Decidir Chatwoot flow').first().json;\n\nif (source.existingConvId) {\n  return [{\n    json: {\n      ...source,\n      contactId: source.existingContactId ?? source.contactId ?? null,\n      convId: source.existingConvId,\n      needCreateConversation: false\n    }\n  }];\n}\n\nconst conversations = $input.first().json.payload ?? [];\nconst preferredInboxId = Number($env.CHATWOOT_INBOX_ID || 0);\nconst sorted = [...conversations].sort((a, b) => Number(b.last_activity_at ?? b.updated_at ?? b.id ?? 0) - Number(a.last_activity_at ?? a.updated_at ?? a.id ?? 0));\nconst preferred = preferredInboxId ? sorted.filter((conversation) => Number(conversation.inbox_id) === preferredInboxId) : sorted;\nconst pool = preferred.length ? preferred : sorted;\nconst chosen = pool.find((conversation) => conversation.status === 'open') ?? pool[0] ?? null;\n\nreturn [{\n  json: {\n    ...source,\n    contactId: source.existingContactId ?? source.contactId ?? null,\n    convId: chosen?.id ?? null,\n    needCreateConversation: !chosen\n  }\n}];"
      },
