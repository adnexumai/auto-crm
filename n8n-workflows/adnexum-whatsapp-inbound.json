        "jsCode": "// Extraer primer resultado\nconst data = $input.first().json;\nconst items = data.items ?? [];\nconst prospect = items[0] ?? null;\nif (!prospect) {\n  return [{ json: { noProspect: true } }];\n}\nreturn [{ json: { prospect } }];"
