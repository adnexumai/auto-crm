        "jsCode": "// Etiqueta según estado CRM\nconst ESTADO_LABEL = {\n  enviado: 'prospecto-nuevo',\n  contactado: 'contactado',\n  respondio: 'respondio',\n  agendado: 'llamada-agendada',\n  seguimiento: 'en-seguimiento',\n  cerrado_positivo: 'cliente',\n  cerrado_negativo: 'descartado'\n};\nconst estado = $json.estado ?? 'enviado';\nconst label = ESTADO_LABEL[estado] ?? 'prospecto-nuevo';\nreturn [{ json: { ...$json, label } }];"
      },
