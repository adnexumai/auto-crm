    {
      "parameters": {
        "jsCode": "const source = $('Decidir contacto').first().json;\nconst conversations = $input.first().json.payload ?? [];\nconst preferredInboxId = 2;\nconst sorted = [...conversations].sort((a, b) => Number(b.last_activity_at ?? b.id ?? 0) - Number(a.last_activity_at ?? a.id ?? 0));\nconst sameInbox = preferredInboxId ? sorted.filter((conversation) => Number(conversation.inbox_id) === preferredInboxId) : sorted;\nconst pool = sameInbox.length ? sameInbox : sorted;\nconst chosen = pool.find((conversation) => conversation.status === 'open') ?? pool[0] ?? null;\nreturn [{ json: { ...source, contactId: source.existingContactId, convId: chosen?.id ?? null, needCreateConversation: !chosen } }];"
      },
