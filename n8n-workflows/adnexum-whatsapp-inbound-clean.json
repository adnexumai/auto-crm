    {
      "parameters": {
        "jsCode": "const contacts = $input.first().json.payload ?? [];\nconst source = $('Extraer campos').first().json;\nconst crm = $('CRM: Grabar mensaje').first().json ?? {};\nconst preferredInboxId = 2;\nlet contact = contacts[0] ?? null;\nif (preferredInboxId && contacts.length) {\n  contact = contacts.find((candidate) =>\n    (candidate.contact_inboxes ?? []).some((inboxRef) => Number(inboxRef.inbox?.id) === preferredInboxId)\n  ) ?? contact;\n}\nreturn [{ json: { ...source, prospect: crm.prospecto ?? null, existingContactId: contact?.id ?? null, needCreateContact: !contact } }];"
      },
