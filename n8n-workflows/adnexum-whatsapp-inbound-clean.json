    {
      "parameters": {
        "jsCode": "const createPath = $('Chatwoot: Crear conversacion').all();\nconst fromCreatedContact = $('Preparar contacto creado').all()[0]?.json;\nconst fromExistingConversation = $('Resolver conversacion existente').all()[0]?.json;\nconst current = $input.first().json;\nconst source = fromCreatedContact ?? fromExistingConversation ?? current;\nconst convId = createPath.length > 0 ? createPath[0].json.id : (current.convId ?? source.convId);\nconst prospect = source.prospect ?? {};\nreturn [{ json: { ...source, prospect, prospectId: prospect.id ?? null, convId, labels: ['pipe_respondio', 'temp_tibio'] } }];"
